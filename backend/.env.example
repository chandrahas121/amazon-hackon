# Copy this file to .env and fill in your values.
# Never commit .env to Git.

# ─── Django core ──────────────────────────────────────────────────────────────
SECRET_KEY=your-strong-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev — leave blank to use SQLite (db.sqlite3)
# DATABASE_URL=sqlite:///db.sqlite3

# AWS RDS PostgreSQL (set this on Elastic Beanstalk)
# DATABASE_URL=postgres://revive_user:password@your-rds-host.rds.amazonaws.com:5432/revive

# ─── CORS / CSRF ──────────────────────────────────────────────────────────────
# Comma-separated. Add your CloudFront URL for production.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── ML / LLM (used by the ml/ module — Track A) ─────────────────────────────
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-3-haiku

# AWS Bedrock (production swap — one env var change)
# LLM_PROVIDER=bedrock
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-south-1
# BEDROCK_MODEL_ID=anthropic.claude-haiku-20240307-v1:0

# ─── Redis (optional — grade cache + demand index) ────────────────────────────
USE_REDIS=false
# REDIS_HOST=localhost
# REDIS_PORT=6379
